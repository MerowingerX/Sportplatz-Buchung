# ── Notion ────────────────────────────────────────────────────────────────────
NOTION_API_KEY=secret_...             # Notion Integration Token (Settings → Integrations)
NOTION_BUCHUNGEN_DB_ID=               # Datenbank für Platzbuchungen
NOTION_SERIEN_DB_ID=                  # Datenbank für Buchungsserien (wöchentliche Trainings etc.)
NOTION_NUTZER_DB_ID=                  # Datenbank für Benutzerkonten
NOTION_AUFGABEN_DB_ID=                # Datenbank für Aufgaben / Schwarzes Brett
NOTION_EVENTS_DB_ID=                  # optional – externe Termine ohne Platzbezug (z. B. Turniere auswärts)
NOTION_MANNSCHAFTEN_DB_ID=            # optional – Mannschaftsliste mit Trainer und fussball.de-Team-ID

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string  # Signaturschlüssel für Login-Cookies, mind. 32 Zeichen
JWT_ALGORITHM=HS256                   # Signaturalgorithmus (nicht ändern)
JWT_EXPIRE_HOURS=8                    # Sitzungsdauer in Stunden

# ── E-Mail (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com            # Hostname des Mailservers
SMTP_PORT=587                         # 587 = STARTTLS, 465 = SSL/TLS
SMTP_USER=user@example.com            # Anmeldename beim Mailserver
SMTP_PASSWORD=                        # SMTP-Passwort
SMTP_FROM=buchung@example.com         # Absenderadresse für ausgehende Mails
ADMIN_EMAIL=                          # optional – Empfänger für Crash-Mails (fällt auf SMTP_FROM zurück)

# ── Buchungssystem-URL ────────────────────────────────────────────────────────
BOOKING_URL=https://buchung.meinverein.de  # öffentlich erreichbare URL, wird in E-Mails verlinkt

# ── Standort (Sonnenuntergangsberechnung) ─────────────────────────────────────
LOCATION_LAT=52.264                   # Breitengrad des Sportplatzes
LOCATION_LON=10.639                   # Längengrad des Sportplatzes
LOCATION_NAME=Cremlingen/Germany      # Freitext, nur für Logs

# ── fussball.de / api-fussball.de ─────────────────────────────────────────────
FUSSBALL_DE_VEREINSSEITE=             # optional – URL der Vereinsseite auf fussball.de
APIFUSSBALL_TOKEN=                    # optional – API-Token für api-fussball.de (erneuern wenn 401)

# ── Instagram (Matchday-Karussell) ────────────────────────────────────────────
INSTAGRAM_ACCOUNT_ID=                 # optional – Instagram Business-Account-ID (Meta Business Manager)
INSTAGRAM_ACCESS_TOKEN=               # optional – Page Access Token (Graph API Explorer; erneuern wenn Fehler 190)
